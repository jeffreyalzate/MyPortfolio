@{
    ViewData["Title"] = "Skills";
}
<div class="container mt-4">
    <div class="card shadow-sm rounded-3">
        <div class="card-body">

            <h4 class="mb-4">Skills</h4>

            <div class="row">

                <!-- Programming Languages -->
                <div class="col-md-6 mb-3">
                    <h6 class="fw-bold">Programming Languages</h6>
                    <span class="badge bg-primary me-1 mb-1">C#</span>
                    <span class="badge bg-primary me-1 mb-1">VB.NET</span>
                    <span class="badge bg-primary me-1 mb-1">VB6</span>
                    <span class="badge bg-primary me-1 mb-1">ASP.NET (Web Forms)</span>
                    <span class="badge bg-primary me-1 mb-1">VBA</span>
                    <span class="badge bg-primary me-1 mb-1">HTML</span>
                </div>

                <!-- Databases -->
                <div class="col-md-6 mb-3">
                    <h6 class="fw-bold">Databases</h6>
                    <span class="badge bg-success me-1 mb-1">SQL Server</span>
                    <span class="badge bg-success me-1 mb-1">MySQL</span>
                    <span class="badge bg-success me-1 mb-1">MS Access</span>
                </div>

                <!-- Tools & Technologies -->
                <div class="col-md-6 mb-3">
                    <h6 class="fw-bold">Tools & Technologies</h6>
                    <span class="badge bg-warning text-dark me-1 mb-1">SSIS</span>
                    <span class="badge bg-warning text-dark me-1 mb-1">SSRS</span>
                    <span class="badge bg-warning text-dark me-1 mb-1">Service-Now Ticketing System</span>
                    <span class="badge bg-warning text-dark me-1 mb-1">Team Foundatin Server</span>
                    <span class="badge bg-warning text-dark me-1 mb-1">XML</span>
                </div>

                <!-- Other Skills -->
                <div class="col-md-6 mb-3">
                    <h6 class="fw-bold">Other</h6>
                    <span class="badge bg-secondary me-1 mb-1">SDLC</span>
                    <span class="badge bg-secondary me-1 mb-1">Debugging</span>
                    <span class="badge bg-secondary me-1 mb-1">Production Support</span>
                    <span class="badge bg-secondary me-1 mb-1">GitHub (Learning)</span>
                    <span class="badge bg-secondary me-1 mb-1">Jira (Learning)</span>
                    <span class="badge bg-secondary me-1 mb-1">APIs (Basic)</span>
                </div>

            </div>

        </div>
    </div>
</div>